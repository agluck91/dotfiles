{% if host_package == "full" %}
export PATH=$HOME/.config/scripts:$HOME/.pyenv/bin/:$HOME/.volta/bin/:$HOME/.cargo/bin:$PATH
{% endif %}
export ZSH="$HOME/.oh-my-zsh"
export CONFIG="$HOME/.config"
export EDITOR="/usr/bin/nvim"
export VISUAL="/usr/bin/nvim"
export TERM="xterm-256color"
export LANG="en_US.UTF-8"
export LC_ALL="en_US.UTF-8"
export LC_CTYPE="en_US.UTF-8"

plugins=(
  colored-man-pages
  command-not-found
  ripgrep
  rust
  fd
  mosh
  zsh-autosuggestions
  zsh-syntax-highlighting
  zsh-interactive-cd
  zsh-navigation-tools
  zoxide
  starship
)

source $ZSH/oh-my-zsh.sh
source $HOME/.aliases
#This is a hack to get zellij completions working,
#I am still trying to figure out what compinit does not pick it up
#I source is directly for now because I want the aliases to be available
{% if host_package == "full" %}
source $CONFIG/completions/_zellij >> /dev/null 2>&1
{% endif %}

