#System Aliases
alias ls="exa --icons -gh --group-directories-first"
alias ll="exa --icons -gh --group-directories-first -l"
alias la="exa --icons -gh --group-directories-first -a"
alias lla="exa --icons -gh --group-directories-first -la"
alias llt="exa --icons --group-directories-first -T"
alias cc="/bin/cat"
alias cat="batcat -p -P"
alias rm="rm -i"
alias cp="cp -i"
alias mv="mv -i"
alias zshrc="nvim ~/.zshrc"
alias tf="tail -f -n 1000"
alias h="history"

#Misc aliases
alias lg="lazygit"
alias vim="nvim"
alias zs="zellij-smart-sessionizer"

#Docker aliases
{% if host_package == "full" %}
alias drm="docker rm -f $(docker ps -aq)"
alias drmi="docker rmi -f $(docker images -aq)"
alias dclean="docker system prune -a"
alias dnuke="drm; drmi; docker system prune -a --volumes --force"
alias d="docker"
alias dc="docker compose"
alias dcu="docker compose up"
alias dcd="docker compose down"
alias dcud="docker compose up -d"
alias dr="docker run"
alias dex="docker exec -it"
{% else %}
#Docker not installed, if you want to add you either need to:
#  - add this host to the full role
#  - add docker to the default roles
{% endif %}

#Git Aliases
alias g="git"
alias gs="git status"
alias gaa="git add --all"
alias gc="git commit"
alias gcm="git commit -m"
alias gca="git commit --amend"
alias gco="git checkout"
alias gcb="git checkout -b"
alias gbr="git branch"
alias gpl="git pull"
alias gp="git push"
